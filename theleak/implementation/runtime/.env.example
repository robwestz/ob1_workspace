# =============================================================================
# OB1 Agentic Architecture — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# Supabase Connection (from your OB1 setup — see docs/01-getting-started.md)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OB1 Access Key (same as SUPABASE_SERVICE_ROLE_KEY unless you set up a custom key)
OB1_ACCESS_KEY=your-access-key

# Anthropic API Key (for LLM calls — https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-key

# OpenAI API Key (for embeddings in memory system — https://platform.openai.com)
OPENAI_API_KEY=your-openai-key

# --- Optional: Defaults & Limits -------------------------------------------

# Model shorthand: haiku, sonnet, or opus (default: sonnet)
OB1_MODEL=sonnet

# Maximum conversation turns per session (default: 50)
OB1_MAX_TURNS=50

# Maximum total tokens per session (default: 1000000)
OB1_MAX_BUDGET_TOKENS=1000000

# Maximum USD spend per session (default: 10.00)
OB1_MAX_BUDGET_USD=10.00

# --- Optional: Debug -------------------------------------------------------

# Set to any value to enable verbose error output
# OB1_DEBUG=1
